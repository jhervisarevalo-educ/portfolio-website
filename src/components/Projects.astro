---
const projects = [
  {
    title: 'Collar Sort',
    description: 'Native Android app for garment production tracking. Manages orders, product & material inventory, production across 4 stages (Cutting, Stitching, Embroidery, Finishing), role-based auth, and a dashboard with pie chart analytics.',
    tags: ['Kotlin', 'Room DB', 'MVVM', 'Android SDK', 'Coil', 'MPAndroidChart'],
    link: 'https://github.com/Larusu/Collar-Sort',
    gradient: 'from-purple-600/20 to-cyan-500/20',
  },
  {
    title: 'BluPlan',
    description: 'Java Swing desktop application for planning fixed deposit accounts. Features full CRUD operations, MySQL database integration, maturity date and interest calculations, and savings goal tracking.',
    tags: ['Java', 'Swing', 'MySQL', 'JDBC', 'Maven'],
    link: 'https://github.com/Larusu/blu-plan',
    gradient: 'from-cyan-500/20 to-emerald-500/20',
  },
  {
    title: 'BankQueue',
    description: 'C++ command-line bank teller queue simulation with separate customer and teller interfaces. Supports regular and VIP priority queues, deposit, withdrawal, and transfer transactions, receipt generation, and statistics tracking.',
    tags: ['C++', 'File I/O', 'Makefile', 'Data Structures'],
    link: 'https://github.com/Larusu/bank-queue',
    gradient: 'from-orange-500/20 to-pink-500/20',
  },
];
---

<section id="projects" class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="reveal">
      <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4 text-center">
        <span class="gradient-text">Projects</span>
      </h2>
      <p class="text-slate-400 text-center mb-16 max-w-xl mx-auto">
        A selection of things I've built
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      {projects.map((project, i) => (
        <a
          href={project.link}
          target="_blank"
          rel="noopener noreferrer"
          class={`reveal-stagger project-card group block p-6 rounded-2xl border border-white/5 bg-gradient-to-br ${project.gradient} backdrop-blur-sm glow-border transition-all duration-300 hover:-translate-y-2`}
          style={`transition-delay: ${i * 150}ms`}
        >
          <div class="flex items-center justify-between mb-4">
            <svg class="w-8 h-8 text-slate-400 group-hover:text-space-glow transition-colors duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
            </svg>
            <div class="flex items-center gap-2">
              <span class="px-2.5 py-0.5 rounded-full text-[10px] font-medium bg-purple-500/15 text-purple-300 border border-purple-500/30">
                Group Project
              </span>
              <svg class="w-5 h-5 text-slate-500 group-hover:text-space-glow transition-all duration-200 group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </div>
          </div>

          <h3 class="text-xl font-heading font-semibold mb-2 text-white group-hover:text-space-glow transition-colors duration-200">
            {project.title}
          </h3>
          <p class="text-slate-400 text-sm mb-4 leading-relaxed" set:html={project.description} />

          <div class="flex flex-wrap gap-2">
            {project.tags.map((tag) => (
              <span class="px-3 py-1 rounded-full text-xs font-medium bg-white/5 text-slate-300 border border-white/10">
                {tag}
              </span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
